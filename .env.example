# GEMINI_API_KEY: Required for AI features. Set this in Vercel environment variables for production.
GEMINI_API_KEY="your-gemini-api-key-here"

# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:4141"

# VITE_DEV_MODE: Set to "true" to enable developer testing tools. Set to "false" for production.
VITE_DEV_MODE="false"
